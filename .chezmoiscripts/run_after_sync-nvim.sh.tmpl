{{- if ne .chezmoi.os "windows" -}}
#!/bin/sh
set -eu

src={{ quote (joinPath .chezmoi.sourceDir "common" "nvim") }}
dest={{ quote (joinPath .chezmoi.homeDir ".config" "nvim") }}

if ! command -v rsync >/dev/null 2>&1; then
  echo "rsync is required to sync Neovim config" >&2
  exit 1
fi

mkdir -p "$(dirname "$dest")"
rsync -a --delete \
  --exclude 'lazy-lock.json' \
  --exclude 'lazyvim.json' \
  "$src"/ "$dest"/
{{- end }}
